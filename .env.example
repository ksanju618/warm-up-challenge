# Copy this file to .env and fill in your real key. Never commit .env itself.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional - defaults to gemini-2.5-flash if unset.
# If your API key has access to newer models, you can try gemini-3-flash
# or gemini-3.5-flash for potentially better quality.
GEMINI_MODEL=gemini-2.5-flash
